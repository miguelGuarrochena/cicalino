# ==========================================================================
# Cicalino - variables de entorno
# Copiar a .env.local y completar. NO commitear .env.local.
# ==========================================================================

# --- Base de datos (Neon Postgres) ---
# Connection string con pooling que da Neon (postgresql://...neon.tech/...)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/cicalino?sslmode=require"

# --- App ---
# URL publica de la app (para armar los links del QR)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Web Push (VAPID) --- (se completa cuando integremos notificaciones push)
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hola@cicalino.ar"

# --- Mercado Pago --- (etapa posterior, no prioritario aun)
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""
