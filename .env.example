# ==========================================================================
# Cicalino - variables de entorno (PLANTILLA)
# Copiar a .env.local y completar con valores reales.
# ⚠️ NUNCA poner claves/contraseñas reales acá: .env.example SE COMMITEA a git.
# ==========================================================================

# --- Supabase (backend + auth + realtime) ---
# Dashboard del proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
# Publishable key (segura para el navegador). Debe ir con NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
# SECRET key: SOLO server, NUNCA exponer ni commitear. Va únicamente en .env.local.
SUPABASE_SECRET_KEY="sb_secret_xxx"

# --- Base de datos (para migraciones con Drizzle) ---
# Supabase → Settings → Database → Connection string.
# Si la contraseña tiene caracteres especiales (& @ : / ?), codificalos (& = %26).
DATABASE_URL="postgresql://postgres:TU-PASSWORD@db.TU-PROYECTO.supabase.co:5432/postgres"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Web Push (VAPID) --- (se completa cuando integremos notificaciones push)
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:info@cicalino.net"

# --- Mercado Pago --- (etapa posterior, no prioritario aun)
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""
